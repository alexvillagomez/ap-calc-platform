{
  "name": "ap-calc-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "seed:topics": "tsx scripts/seed-topics.ts",
    "seed:mcat": "tsx scripts/seed-mcat-taxonomy.ts",
    "mcat:expand": "tsx scripts/expand-mcat-keywords.ts",
    "mcat:embed": "tsx scripts/embed-mcat.ts",
    "mcat:clean-unembedded": "tsx scripts/delete-unembedded-mcat.ts",
    "mcat:blueprints": "tsx scripts/backfill-mcat-blueprints.ts",
    "mcat:audit-scope": "tsx scripts/audit-mcat-scope.ts",
    "math:validate": "tsx scripts/validate-math-taxonomy.ts",
    "math:seed": "tsx scripts/seed-math-taxonomy.ts",
    "math:embed": "tsx scripts/embed-math.ts",
    "math:blueprints": "tsx scripts/backfill-math-blueprints.ts",
